# Groq API Key and Model (Required for live GenAI model, fallback offline mock mode used if absent)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Environment: "development" (default) or "production".
# In production, API docs are disabled and weak/default auth secrets are rejected at startup.
ENV=development

# SQLite database file path (Optional: defaults to stadium_twin.db)
DATABASE_PATH=

# Rate Limit settings for chat requests (Optional: default 5 requests per 10 seconds)
RATE_LIMIT_LIMIT=5
RATE_LIMIT_WINDOW=10

# Allowed CORS Origins (Optional: comma-separated list, defaults to http://localhost:5173)
ALLOWED_ORIGINS=http://localhost:5173

# Staff Portal Auth settings
# Change this passcode before any real deployment.
STAFF_PASSCODE=change-me

# Strong signing secret for staff JWTs. MUST be a random 32-byte (64 hex char) value in production.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-64-char-hex-string
